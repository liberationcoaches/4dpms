graph TB
    Start([Start]) --> Portal{Which Portal?}
    
    Portal -->|Main App| MainPortal[Main Application<br/>app.yourplatform.com]
    Portal -->|Super Admin| SuperAdmin[Super Admin Portal<br/>admin.yourplatform.com]
    Portal -->|Reviewer| ReviewerPortal[Reviewer Portal<br/>review.yourplatform.com]
    
    %% SUPER ADMIN FLOW
    SuperAdmin --> SALogin[Super Admin Login<br/>Email + Password + 2FA]
    SALogin --> SADash[Super Admin Dashboard]
    SADash --> SAActions{Super Admin Actions}
    
    SAActions --> ViewOrgs[View All Organizations]
    SAActions --> CreateOrg[Create New Organization]
    SAActions --> AssignRev[Assign/Reassign Reviewers]
    SAActions --> Analytics[Platform Analytics]
    
    CreateOrg --> OrgDetails[Enter Org Details:<br/>• Company Name<br/>• Industry<br/>• Plan Type<br/>• Boss Email]
    OrgDetails --> GenerateCreds[System Generates:<br/>• Unique Org ID<br/>• Boss Credentials<br/>• Workspace]
    GenerateCreds --> SendBossEmail[Email Sent to Boss:<br/>Welcome + Login Link<br/>Temporary Password]
    
    AssignRev --> SelectOrg[Select Organization]
    SelectOrg --> ChooseReviewer[Choose Reviewer<br/>from Reviewer Pool]
    ChooseReviewer --> NotifyReviewer[Notify Reviewer<br/>of Assignment]
    
    %% MAIN APPLICATION FLOW
    MainPortal --> LoginType{User Type?}
    
    %% BOSS FLOW
    LoginType -->|First Time Boss| BossFirstLogin[Boss Clicks Email Link]
    LoginType -->|Returning User| RegularLogin[Regular Login<br/>Email + Password]
    
    BossFirstLogin --> BossSetPass[Boss Sets New Password<br/>+ Security Questions]
    BossSetPass --> BossDash[Boss Dashboard]
    RegularLogin --> CheckRole{Check Role}
    
    BossDash --> BossOptions{Boss Actions}
    BossOptions --> ViewAllTeams[View All Managers<br/>& Teams]
    BossOptions --> CreateManager[Create Manager Account]
    BossOptions --> SetReviewCycle[Configure Review Cycles]
    BossOptions --> ViewReports[View Org Reports]
    
    CreateManager --> MgrForm[Fill Manager Form:<br/>• Name<br/>• Email<br/>• Department<br/>• Permissions]
    MgrForm --> GenerateMgrCreds[System Generates<br/>Manager Credentials]
    GenerateMgrCreds --> SendMgrEmail[Email to Manager:<br/>Welcome Link<br/>Temporary Password]
    
    %% MANAGER FLOW
    SendMgrEmail --> MgrFirstLogin[Manager Clicks Link]
    MgrFirstLogin --> MgrSetPass[Manager Sets Password]
    MgrSetPass --> MgrDash[Manager Dashboard]
    
    CheckRole -->|Manager| MgrDash
    CheckRole -->|Employee| EmpDash
    CheckRole -->|Boss| BossDash
    
    MgrDash --> MgrOptions{Manager Actions}
    MgrOptions --> ViewTeam[View My Team]
    MgrOptions --> CreateEmp[Create Employee Account]
    MgrOptions --> AddFeedback[Add Feedback/Notes]
    MgrOptions --> ViewTeamPerf[View Team Performance]
    
    CreateEmp --> EmpForm[Fill Employee Form:<br/>• Name<br/>• Email<br/>• Position<br/>• Department<br/>• Employee ID]
    EmpForm --> GenerateEmpCreds[System Generates<br/>Employee Credentials]
    GenerateEmpCreds --> SendEmpEmail[Email to Employee:<br/>Welcome Link<br/>Temporary Password]
    
    %% EMPLOYEE FLOW
    SendEmpEmail --> EmpFirstLogin[Employee Clicks Link]
    EmpFirstLogin --> EmpSetPass[Employee Sets Password]
    EmpSetPass --> EmpDash[Employee Dashboard]
    
    EmpDash --> EmpView[View:<br/>• My Scores<br/>• Next Review Date<br/>• Feedback<br/>• Action Items<br/>• Performance History]
    
    %% REVIEWER FLOW
    ReviewerPortal --> RevLogin[Reviewer Login<br/>Email + Password + 2FA]
    RevLogin --> RevDash[Reviewer Dashboard]
    RevDash --> RevActions{Reviewer Actions}
    
    RevActions --> ViewAssignedOrgs[View Assigned<br/>Organizations]
    RevActions --> SelectOrgReview[Select Org to Review]
    
    SelectOrgReview --> ViewEmployees[View All Employees<br/>in Organization]
    ViewEmployees --> SelectEmployee[Select Employee<br/>to Review]
    SelectEmployee --> ReviewForm[Review Form:<br/>• Performance Scores<br/>• Comments<br/>• Improvement Areas<br/>• Goals]
    ReviewForm --> SubmitReview[Submit Review]
    SubmitReview --> LockReview[Review Locked<br/>& Timestamped]
    LockReview --> NotifyUsers[Notify Employee,<br/>Manager, Boss]
    
    NotifyUsers --> UpdateDashboards[Update All<br/>Dashboards]
    UpdateDashboards --> EmpView
    UpdateDashboards --> ViewTeamPerf
    UpdateDashboards --> ViewAllTeams
    
    %% SECURITY NOTES
    SADash -.->|No Access| MainPortal
    RevDash -.->|No Access| MainPortal
    RevDash -.->|No Access| SuperAdmin
    MgrDash -.->|No Access| ReviewerPortal
    EmpDash -.->|No Access| ReviewerPortal
    BossDash -.->|No Access| ReviewerPortal
    
    style SuperAdmin fill:#ff6b6b
    style SADash fill:#ff6b6b
    style ReviewerPortal fill:#4ecdc4
    style RevDash fill:#4ecdc4
    style MainPortal fill:#95e1d3
    style BossDash fill:#f38181
    style MgrDash fill:#aa96da
    style EmpDash fill:#fcbad3
    style Start fill:#e1f5ff